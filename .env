# --- Discord Bot Settings ---
# Your main bot token from the Discord Developer Portal
DISCORD_TOKEN=your_discord_bot_token_here

# --- Database Settings ---
# MongoDB connection string (e.g., MongoDB Atlas URI)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/your_database

# --- Web Dashboard OAuth2 Settings ---
# Found in the OAuth2 section of your Discord Developer Portal
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# --- Web Server Settings ---
# Port for the FastAPI dashboard (Optional: Railway usually assigns this automatically)
PORT=8000

# --- AI Tools Settings ---
# API key from Groq for the chat summarization command
GROQ_API_KEY=your_groq_api_key_here
